{
  "name": "waka-next",
  "version": "0.0.1",
  "homepage": "https://github.com/consindo/waka-next",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:orchestrator & npm run dev:web",
    "dev:orchestrator": "cd apps/orchestrator && vite dev",
    "dev:web": "cd apps/web && vite dev",
    "build": "npm run build:orchestrator && npm run build:web",
    "build:orchestrator": "cd apps/orchestrator && vite build",
    "build:web": "cd apps/web && vite build && cp -r .netlify ../../",
    "preview": "npm run preview:orchestrator & npm run preview:web",
    "preview:orchestrator": "cd apps/orchestrator && vite preview",
    "preview:web": "cd apps/web && vite preview",
    "check": "npm run check:orchestrator && npm run check:web",
    "check:orchestrator": "cd apps/orchestrator && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:web": "cd apps/web && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/eslint": "^9.6.1",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@date-fns/tz": "^1.4.1",
    "@eslint/js": "^10.0.1",
    "@gera2ld/tarjs": "^0.3.1",
    "@loaders.gl/core": "^4.4.1",
    "@loaders.gl/wkt": "^4.4.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@turf/turf": "^7.3.5",
    "@types/geojson": "^7946.0.16",
    "@zip.js/zip.js": "^2.8.26",
    "confbox": "^0.2.4",
    "date-fns": "^4.1.0",
    "maplibre-gl": "^5.23.0",
    "sql.js": "^1.14.1",
    "udsv": "^0.7.3"
  }
}
